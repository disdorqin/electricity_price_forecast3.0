# Local secrets — COPY this file to `.env.local` and fill in real values.
# `.env.local` is gitignored; never commit it.

# Real MySQL ledger URL. Encode `#` in the password as `%23`.
EFM3_DB_URL=mysql+pymysql://root:YOUR_PASSWORD@127.0.0.1:3306/efm3

# Any non-empty key; required for non-localhost API access.
EFM3_API_KEY=local-dev-key

# Enable ops endpoints (init-db / update-data / dry-run / shadow / export / formal).
# Leave false unless you are actively running the one-click chain.
EFM3_OPS_ENABLED=true

EFM3_DATA_ROOT=data
EFM2_5_ROOT=D:/path/to/electricity_forecast_model2.5
