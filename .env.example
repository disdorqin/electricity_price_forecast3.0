# EFM3 API-only Control Plane — example environment (committable template).
# Copy to `.env` or `.env.local` and fill in real values locally.
# NEVER commit a real password. Use `***` as a placeholder here.

# MySQL ledger connection (the MAIN ledger). Format:
#   mysql+pymysql://USER:PASSWORD@HOST:PORT/DB
# If your password contains `#`, URL-encode it as `%23`
#   e.g. mysql+pymysql://root:SuperSecret123%23@127.0.0.1:3306/efm3
EFM3_DB_URL=mysql+pymysql://root:***@127.0.0.1:3306/efm3

# API key required for non-localhost access to the Control Plane API.
EFM3_API_KEY=change-me

# Ops endpoints trigger REAL pipeline side effects (data update / dry-run /
# formal / export). Keep them DISABLED unless you explicitly need them.
EFM3_OPS_ENABLED=false

# Local data roots (used by the CLI / orchestrator, not the API directly).)
EFM3_DATA_ROOT=data
EFM2_5_ROOT=D:/path/to/electricity_forecast_model2.5
